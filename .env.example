# Copy to .env and fill in values. .env is gitignored — never commit it.

# --- Postgres credentials ---
POSTGRES_USER=orbit
POSTGRES_PASSWORD=orbit
POSTGRES_DB=orbit

# Full async SQLAlchemy URL the app connects with (host "db" = compose service).
DATABASE_URL=postgresql+asyncpg://orbit:orbit@db:5432/orbit

# --- JWT / auth ---
# Generate a strong random value in production, e.g. `openssl rand -hex 32`.
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# --- verification ---
# Code lifetime; the dev console sender logs the code (swap to email/SMS in prod).
VERIFICATION_CODE_TTL_MINUTES=30
# Redis logical db holding pending OTP codes (separate from Celery's 0/1).
REDIS_URL=redis://redis:6379/2

# --- cleanup (Celery) ---
CLEANUP_DAYS=2
CLEANUP_INTERVAL_MINUTES=60
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
